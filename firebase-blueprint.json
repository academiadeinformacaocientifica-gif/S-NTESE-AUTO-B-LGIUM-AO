{
  "entities": {
    "Sintese": {
      "title": "Sintese",
      "description": "Uma notícia individual da síntese de imprensa.",
      "type": "object",
      "properties": {
        "date": {
          "type": "string",
          "format": "date",
          "description": "A data da notícia (YYYY-MM-DD)."
        },
        "category": {
          "type": "string",
          "enum": ["Política", "Economia"],
          "description": "A categoria da notícia."
        },
        "title": {
          "type": "string",
          "description": "O título traduzido da notícia (Norma 1945)."
        },
        "leed": {
          "type": "string",
          "description": "O LEED (Quem, O quê, Onde, Quando, Porquê)."
        },
        "body": {
          "type": "string",
          "description": "O resumo da notícia (Norma 1945)."
        },
        "link": {
          "type": "string",
          "format": "uri",
          "description": "O URL original da notícia."
        },
        "source": {
          "type": "string",
          "description": "O nome do jornal/fonte."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp de criação."
        }
      },
      "required": ["date", "category", "title", "leed", "body", "link", "source", "createdAt"]
    }
  },
  "firestore": {
    "/sinteses/{sinteseId}": {
      "schema": "Sintese",
      "description": "Colecção de sínteses diárias."
    }
  }
}
