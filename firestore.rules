rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isValidClipping(data) {
      return data.title is string && data.title.size() < 500 &&
             data.leed is string && data.leed.size() < 2000 &&
             data.body is string && data.body.size() < 10000 &&
             data.link is string && data.link.size() < 1000 &&
             data.source is string && data.source.size() < 100 &&
             data.category in ['Política', 'Economia'] &&
             data.date is string && data.date.matches('^\\d{4}-\\d{2}-\\d{2}$');
    }

    match /clippings/{clippingId} {
      // For MVP, allow public read, but authenticated write
      allow read: if true;
      allow create: if isValidClipping(request.resource.data);
      allow update, delete: if false; // Clippings are immutable once generated
    }
  }
}
